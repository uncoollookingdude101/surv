{
  "name": "@survev/server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx src/build.ts",
    "typecheck": "tsc",
    "start:api": "node --enable-source-maps dist/index.js",
    "start:game": "node --enable-source-maps dist/gameServer.js",
    "dev": "concurrently \"pnpm run dev:api\" \"pnpm run dev:game\"",
    "dev:api": "tsx watch --clear-screen=false --include ../survev-config.hjson src/api/index.ts",
    "dev:game": "tsx watch --clear-screen=false --include ../survev-config.hjson src/gameServer.ts",
    "db:generate": "drizzle-kit generate --config=src/api/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/api/drizzle.config.ts",
    "db:seed": "tsx src/api/db/seed.ts",
    "db:studio": "drizzle-kit studio --config=src/api/drizzle.config.ts",
    "db:wipe": "rm -rf src/api/db/drizzle && tsx src/api/db/wipe.ts",
    "stressTest": "tsx src/stressTest.ts",
    "lint": "cd .. && pnpm lint"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@oslojs/crypto": "^1.0.1",
    "arctic": "^3.7.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "nanotimer": "^0.3.15",
    "obscenity": "^0.4.6",
    "pg": "^8.20.0",
    "proxycheck-ts": "^0.0.11",
    "redis": "^5.12.1",
    "slugify": "^1.6.9",
    "typescript": "^5.9.3",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.64.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/nanotimer": "^0.3.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "unique-username-generator": "^1.5.1"
  }
}
